<section class="brand-story" id="brand-story">
  <div class="brand-story__image">
    {%- if section.settings.image -%}
      <img
        src="{{ section.settings.image | image_url: width: 900 }}"
        alt="{{ section.settings.image.alt | escape }}"
        loading="lazy"
        width="900"
        height="1100"
      >
    {%- else -%}
      <div style="width:100%;height:100%;min-height:500px;background:linear-gradient(135deg, var(--kl-cream) 0%, var(--kl-blush) 100%);display:grid;place-items:center;">
        <span style="font-size:4rem;">🪷</span>
      </div>
    {%- endif -%}
  </div>

  <div class="brand-story__content">
    <p class="subtitle reveal">{{ section.settings.subtitle | default: "Our Heritage" }}</p>
    <blockquote class="brand-story__quote reveal">
      "{{ section.settings.quote | default: "Beauty is not in the face; beauty is a light in the heart — woven into every thread we create." }}"
    </blockquote>

    <div class="brand-story__divider reveal">
      <span></span>
      <span class="ornament">✦</span>
      <span></span>
    </div>

    <h2 class="reveal">{{ section.settings.heading | default: "Rooted in Tradition" }}</h2>
    <p class="reveal">{{ section.settings.body | default: "KomalaLeela was born from a deep reverence for India's textile legacy. Founded in Hyderabad, we bring together master weavers, block-print artisans, and embroidery craftswomen to create pieces that are both timeless and alive." }}</p>
    <p class="reveal">{{ section.settings.body_2 | default: "Every saree, every lehenga, every kurta carries the fingerprints of the artisans who made it — their patience, their pride, and their extraordinary skill." }}</p>

    <div style="margin-top:2rem;" class="reveal">
      <a href="{{ section.settings.button_url | default: '/pages/about' }}" class="btn btn--outline">
        {{ section.settings.button_label | default: "Discover Our Story" }}
      </a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Story",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Story Image" },
    { "type": "text", "id": "subtitle", "label": "Eyebrow Label", "default": "Our Heritage" },
    { "type": "textarea", "id": "quote", "label": "Pull Quote" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Rooted in Tradition" },
    { "type": "textarea", "id": "body", "label": "Body Text (Paragraph 1)" },
    { "type": "textarea", "id": "body_2", "label": "Body Text (Paragraph 2)" },
    { "type": "text", "id": "button_label", "label": "Button Label", "default": "Discover Our Story" },
    { "type": "url", "id": "button_url", "label": "Button URL", "default": "/pages/about" }
  ],
  "presets": [{ "name": "Brand Story" }]
}
{% endschema %}
