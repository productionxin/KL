<footer class="site-footer" id="shopify-section-footer">
  <div class="footer-grid">
    <div class="footer-brand">
      <div class="logo-name">KomalaLeela</div>
      <div class="logo-tagline">Woven with Grace</div>
      <p>{{ section.settings.tagline | default: "Celebrating India's living textile traditions — handcrafted pieces for the modern woman who honours her roots." }}</p>
      <div class="footer-socials">
        {%- if section.settings.instagram != blank -%}
          <a href="{{ section.settings.instagram }}" class="social-link" aria-label="Instagram" target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.facebook != blank -%}
          <a href="{{ section.settings.facebook }}" class="social-link" aria-label="Facebook" target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.pinterest != blank -%}
          <a href="{{ section.settings.pinterest }}" class="social-link" aria-label="Pinterest" target="_blank" rel="noopener">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.77 1.23-5.21 1.23-5.21s-.31-.63-.31-1.56c0-1.46.85-2.55 1.9-2.55.9 0 1.33.67 1.33 1.48 0 .9-.57 2.26-.87 3.51-.25 1.04.51 1.89 1.53 1.89 1.84 0 3.07-2.35 3.07-5.13 0-2.12-1.43-3.71-4.01-3.71-2.93 0-4.76 2.19-4.76 4.64 0 .84.24 1.43.62 1.89.17.2.19.28.13.51-.04.17-.14.57-.18.73-.06.23-.24.31-.44.23-1.24-.51-1.82-1.88-1.82-3.42 0-2.54 2.15-5.6 6.44-5.6 3.45 0 5.73 2.5 5.73 5.18 0 3.55-1.97 6.21-4.87 6.21-.97 0-1.89-.52-2.21-1.1l-.62 2.37c-.22.87-.82 1.95-1.23 2.61.93.28 1.91.43 2.92.43 5.52 0 10-4.48 10-10S17.52 2 12 2z"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="footer-col">
      <h5>Shop</h5>
      <ul>
        <li><a href="/collections/sarees">Sarees</a></li>
        <li><a href="/collections/lehengas">Lehengas</a></li>
        <li><a href="/collections/kurtas">Kurtas</a></li>
        <li><a href="/collections/dupattas">Dupattas</a></li>
        <li><a href="/collections/new">New Arrivals</a></li>
        <li><a href="/collections/sale">Sale</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h5>Help</h5>
      <ul>
        <li><a href="/pages/sizing-guide">Size Guide</a></li>
        <li><a href="/pages/shipping">Shipping & Returns</a></li>
        <li><a href="/pages/care-guide">Care Instructions</a></li>
        <li><a href="/pages/faq">FAQs</a></li>
        <li><a href="/pages/contact">Contact Us</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h5>About</h5>
      <ul>
        <li><a href="/pages/our-story">Our Story</a></li>
        <li><a href="/pages/artisans">Our Artisans</a></li>
        <li><a href="/pages/sustainability">Sustainability</a></li>
        <li><a href="/blogs/journal">Journal</a></li>
        <li><a href="/pages/press">Press</a></li>
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {{ 'now' | date: '%Y' }} KomalaLeela. All rights reserved.</p>
    <div class="payment-icons">
      <span class="payment-icon">VISA</span>
      <span class="payment-icon">MC</span>
      <span class="payment-icon">UPI</span>
      <span class="payment-icon">RazorPay</span>
    </div>
    <div style="display:flex;gap:1.5rem;">
      <a href="/policies/privacy-policy" style="color:rgba(122,107,82,0.6);font-size:0.75rem;transition:color 0.3s;" onmouseover="this.style.color='rgba(201,168,108,0.8)'" onmouseout="this.style.color='rgba(122,107,82,0.6)'">Privacy</a>
      <a href="/policies/terms-of-service" style="color:rgba(122,107,82,0.6);font-size:0.75rem;transition:color 0.3s;" onmouseover="this.style.color='rgba(201,168,108,0.8)'" onmouseout="this.style.color='rgba(122,107,82,0.6)'">Terms</a>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "tagline", "label": "Brand Tagline", "default": "Celebrating India's living textile traditions — handcrafted pieces for the modern woman who honours her roots." },
    { "type": "url", "id": "instagram", "label": "Instagram URL" },
    { "type": "url", "id": "facebook", "label": "Facebook URL" },
    { "type": "url", "id": "pinterest", "label": "Pinterest URL" }
  ],
  "presets": [{ "name": "Footer" }]
}
{% endschema %}
